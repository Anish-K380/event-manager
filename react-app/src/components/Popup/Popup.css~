.popup-container {
  position: fixed;
  bottom: 30px;
  right: 30px;

  background: #ffffff;
  color: #333;
  padding: 16px 20px;
  border-radius: 12px;

  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  min-width: 250px;

  display: flex;
  flex-direction: column;
  gap: 10px;

  animation: slideIn 0.3s ease;
}

.popup-text {
  margin: 0;
  font-size: 14px;
}

.popup-button {
  align-self: flex-end;
  padding: 6px 12px;

  border: none;
  border-radius: 6px;
  background: #4caf50;
  color: white;

  cursor: pointer;
  transition: background 0.2s ease;
}

.popup-button:hover {
  background: #43a047;
}

@keyframes slideIn {
  from {
    transform: translateY(20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
