/* InputPassword.css */

.password-box-container {
  display: flex;
  align-items: center;
  gap: 8px;
}

.password-box-container .input-field {
  flex: 1;
}

.password-button {
  padding: 8px 10px;
  font-size: 0.8rem;
  border-radius: 6px;
  border: none;
  background: #e5e7eb;
  cursor: pointer;
  transition: 0.2s ease;
}

.password-button:hover {
  background: #d1d5db;
}
